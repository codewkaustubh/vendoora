generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String  @id @default(uuid())
  name         String
  email        String  @unique
  phone        String? @unique
  password     String?
  googleId     String? @unique
  profileImage String?
  city         String?
  state        String?
  role         Role    @default(CLIENT)
  isVerified   Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  vendor Vendor?

  bookings      Booking[]      @relation("ClientBookings")
  notifications Notification[]
  products      Product[]      @relation("SellerProducts")
  reviews       Review[]
  wishlists     Wishlist[]
  refreshTokens RefreshToken[] @relation("UserRefreshTokens")

  @@index([email])
  @@index([role])
}

model Vendor {
  id     String @id @default(uuid())
  userId String @unique

  businessName        String
  businessDescription String?

  ownerName String

  category String

  phone String?
  email String?

  gstNumber String?

  city  String
  state String

  address String?

  logo       String?
  coverImage String?

  rating        Float @default(5.0)
  totalReviews  Int   @default(0)
  totalBookings Int   @default(0)

  verificationStatus VerificationStatus @default(PENDING)
  acceptingBookings  Boolean            @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  bookings  Booking[]       @relation("VendorBookings")
  inventory InventoryItem[]
  services  Service[]
  reels     VibeReel[]
  reviews   Review[]

  @@index([city])
  @@index([state])
  @@index([category])
  @@index([rating])
}

model Category {
  id          String  @id @default(uuid())
  name        String  @unique
  slug        String  @unique
  description String?
  icon        String?
  image       String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  services Service[]

  @@index([name])
}

model Service {
  id String @id @default(uuid())

  vendorId   String
  categoryId String

  title       String
  description String?

  startingPrice Float

  priceType PriceType @default(FIXED)

  duration String?

  location String?

  coverImage String?

  isAvailable Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  vendor   Vendor   @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  bookings  Booking[]
  wishlists Wishlist[]

  @@index([vendorId])
  @@index([categoryId])
  @@index([startingPrice])
}

model InventoryItem {
  id         String   @id @default(uuid())
  vendorId   String
  name       String
  units      Int      @default(1)
  hourlyRate Float
  dailyRate  Float
  image      String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  vendor     Vendor   @relation(fields: [vendorId], references: [id], onDelete: Cascade)
}

model Product {
  id String @id @default(uuid())

  sellerId String

  name        String
  description String?

  price Float

  aiSuggestedPrice Float?

  condition ProductCondition

  location String

  image String?

  available Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  seller User @relation("SellerProducts", fields: [sellerId], references: [id], onDelete: Cascade)

  @@index([sellerId])
}

model Booking {
  id String @id @default(uuid())

  clientId  String
  vendorId  String
  serviceId String?

  eventName String
  eventDate DateTime

  startTime String
  endTime   String?

  guestCount Int?

  venue String

  specialRequest String?

  totalPrice Float

  paymentStatus PaymentStatus @default(PENDING)

  status BookingStatus @default(PENDING)

  bookingOtp  String?
  otpVerified Boolean @default(false)

  cancellationReason String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  client  User     @relation("ClientBookings", fields: [clientId], references: [id], onDelete: Cascade)
  vendor  Vendor   @relation("VendorBookings", fields: [vendorId], references: [id], onDelete: Cascade)
  service Service? @relation(fields: [serviceId], references: [id])

  @@index([clientId])
  @@index([vendorId])
  @@index([serviceId])
  @@index([status])
}

model Notification {
  id        String    @id @default(uuid())
  userId    String
  title     String
  message   String
  time      String?
  readAt    DateTime?
  type      String
  read      Boolean   @default(false)
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VibeReel {
  id        String   @id @default(uuid())
  vendorId  String
  title     String
  thumbnail String
  views     Int      @default(0)
  duration  String   @default("0:15")
  createdAt DateTime @default(now())
  vendor    Vendor   @relation(fields: [vendorId], references: [id], onDelete: Cascade)
}

model Review {
  id String @id @default(uuid())

  userId   String
  vendorId String

  rating Int

  comment String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  vendor Vendor @relation(fields: [vendorId], references: [id], onDelete: Cascade)

  @@index([vendorId])
}

model Wishlist {
  id String @id @default(uuid())

  userId    String
  serviceId String

  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  service Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@unique([userId, serviceId])
}

enum Role {
  CLIENT
  VENDOR
  ADMIN
}

enum BookingStatus {
  PENDING
  SCHEDULED
  IN_PROGRESS
  COMPLETED
  DECLINED
}

enum PriceType {
  FIXED
  HOURLY
  DAILY
}

enum ProductCondition {
  MINT
  EXCELLENT
  GOOD
  FAIR
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum VerificationStatus {
  PENDING
  VERIFIED
  REJECTED
}

model RefreshToken {
  id         String  @id @default(uuid())
  token      String  @unique
  userId     String
  deviceId   String? // Identifies a specific device/browser session
  deviceName String? // Human-readable device description (e.g. "Chrome on Windows")
  ipAddress  String? // Client IP address for logging and security audits
  userAgent  String? // Full browser user agent string

  // Refresh Token Rotation (RTR) Support
  isRevoked  Boolean @default(false)
  replacedBy String? // Token that succeeded/replaced this token

  expiresAt DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation("UserRefreshTokens", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
}
